<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HopDelivery.Views.RegisterPage"
             Title="Crear Cuenta">

    <VerticalStackLayout Padding="30" Spacing="20" VerticalOptions="Center">
        <Label Text="Nuevo Usuario" FontSize="28" FontAttributes="Bold" HorizontalOptions="Center" TextColor="#512BD4" Margin="0,0,0,20"/>

        <Entry x:Name="TxtEmail" Placeholder="Correo electrónico" Keyboard="Email" />
        <Entry x:Name="TxtPassword" Placeholder="Contraseña" IsPassword="True" />
        <Entry x:Name="TxtConfirmPassword" Placeholder="Confirmar Contraseña" IsPassword="True" />

        <Button Text="Registrarse" Clicked="OnRegistrarUsuarioClicked" BackgroundColor="#512BD4" TextColor="White" HeightRequest="50" CornerRadius="8" Margin="0,20,0,0" />
    </VerticalStackLayout>
</ContentPage>