<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HopDelivery.Views.LoginPage"
             Title="Login">
    <VerticalStackLayout Padding="30" Spacing="20" VerticalOptions="Center">
        <Label Text="Hop Delivery - Admin" FontSize="24" HorizontalOptions="Center" />
        <Entry x:Name="TxtUser" Placeholder="Usuario" />
        <Entry x:Name="TxtPass" Placeholder="Contraseña" IsPassword="True" />
        <Button Text="Entrar" Clicked="OnLoginClicked" BackgroundColor="#512BD4" TextColor="White" />
    </VerticalStackLayout>
</ContentPage>