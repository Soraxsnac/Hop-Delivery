<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HopDelivery.Views.LoginPage"
             Title="LoginPage">
    <VerticalStackLayout>
        <Entry x:Name="txtUsuario" Placeholder="Usuario" Margin="20" />
        <Entry x:Name="txtPassword" Placeholder="Contraseña" IsPassword="True" Margin="20" />
        <Button Text="Iniciar Sesión" Margin="20" Clicked="Button_Clicked"/>
        <Label x:Name="lblToken" TextColor="Red" Margin="20" />
    </VerticalStackLayout>
</ContentPage>