<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HopDelivery.Views.Catalogos.EditarCervezaPage"
             Title="Editar Cerveza">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">
            <Label Text="Modificar Cerveza" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center" />

            <Label x:Name="LblId" TextColor="Gray" HorizontalOptions="Center"/>

            <Entry x:Name="TxtNombre" Placeholder="Nombre de la cerveza" />
            <Entry x:Name="TxtTipo" Placeholder="Tipo (Ej. IPA, Stout)" />
            <Entry x:Name="TxtABV" Placeholder="ABV % (Ej. 6.5)" Keyboard="Numeric" />
            <Entry x:Name="TxtIBU" Placeholder="Amargor IBU (Ej. 40)" Keyboard="Numeric" />
            <Entry x:Name="TxtDescripcion" Placeholder="Descripción corta" />

            <Entry x:Name="TxtImagenUrl" Placeholder="URL de la imagen (Link de internet)" />

            <Label Text="Calificación actual:" FontSize="16" FontAttributes="Bold" Margin="0,10,0,0" />
            <Picker x:Name="PickerCalificacion" Title="Cambiar estrellas">
                <x:String>0 Estrellas (Pésima)</x:String>
                <x:String>1 Estrella</x:String>
                <x:String>2 Estrellas</x:String>
                <x:String>3 Estrellas (Regular)</x:String>
                <x:String>4 Estrellas</x:String>
                <x:String>5 Estrellas (Excelente)</x:String>
            </Picker>

            <Button Text="Guardar Cambios" Clicked="OnActualizarClicked" BackgroundColor="DarkGreen" TextColor="White" Margin="0,20,0,0" />
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>