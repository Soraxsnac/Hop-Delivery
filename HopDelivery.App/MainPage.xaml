<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HopDelivery.App.MainPage"
             Title="Catálogo de Cervezas">

    <Grid RowDefinitions="Auto, *">
        <HorizontalStackLayout Grid.Row="0" Spacing="10" Padding="10" HorizontalOptions="Center">
            <Button x:Name="BtnRefrescar" Text="Refrescar Catálogo" Clicked="OnRefrescarClicked" WidthRequest="200" />
            <Button Text="+ Nueva Cerveza" Clicked="OnAgregarClicked" BackgroundColor="Green" TextColor="White" />
        </HorizontalStackLayout>

        <CollectionView x:Name="ListaCervezas" Grid.Row="1" Margin="10">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="0,5" Padding="10" BorderColor="LightGray" CornerRadius="8">
                        <Grid ColumnDefinitions="80, *, Auto">

                            <Image Grid.Column="0" Source="https://img.icons8.com/color/96/beer.png" HeightRequest="60" WidthRequest="60" Margin="0,0,10,0"/>

                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                <Label Text="{Binding Nombre}" FontSize="18" FontAttributes="Bold" />
                                <Label Text="{Binding Tipo}" FontSize="14" TextColor="Gray" />
                                <Label Text="{Binding Calificacion, StringFormat='{0} ⭐ Estrellas'}" FontSize="14" TextColor="#D4AF37" FontAttributes="Bold" />
                            </VerticalStackLayout>

                            <Button Grid.Column="2" Text="Editar" CommandParameter="{Binding .}" Clicked="OnEditarClicked" VerticalOptions="Center" HeightRequest="35" Padding="10,5" BackgroundColor="#512BD4" TextColor="White" />

                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>

</ContentPage>