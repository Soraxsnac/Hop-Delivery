<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HopDelivery.MainPage"
             Title="Hop Delivery - Catálogo"
             BackgroundColor="#F5F5F5">

    <Grid RowDefinitions="Auto, *">

        <Frame Grid.Row="0" BackgroundColor="#2C3E50" CornerRadius="0" HasShadow="True" Padding="15">
            <HorizontalStackLayout HorizontalOptions="Center" Spacing="10">
                <Label Text="🍻" FontSize="24" VerticalOptions="Center"/>
                <Label Text="Mis Cervezas &amp; Valoraciones" 
                       FontSize="20" 
                       FontAttributes="Bold" 
                       TextColor="White" 
                       VerticalOptions="Center"/>
            </HorizontalStackLayout>
        </Frame>

        <ScrollView Grid.Row="1" Padding="15">
            <VerticalStackLayout Spacing="15">

                <Button Text="Refrescar Catálogo" 
                        Clicked="OnRefrescarClicked"
                        BackgroundColor="#3498DB" 
                        TextColor="White" 
                        FontAttributes="Bold"
                        CornerRadius="8" />

                <Label Text="Tu bitácora personal está lista para cargar." 
                       HorizontalOptions="Center" 
                       Margin="0,20,0,0" 
                       TextColor="Gray" />

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>