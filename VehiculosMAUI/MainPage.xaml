<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VehiculosMAUI.MainPage"
             Title="Catálogo de Cervezas"
             BackgroundColor="#F5F5F5">

    <Grid RowDefinitions="Auto,*,Auto">

        <Label Grid.Row="0" Text="Nuestras Cervezas" FontSize="26" FontAttributes="Bold" Margin="15" TextColor="#333333" />

        <CollectionView Grid.Row="1" x:Name="CervezasCollection" Margin="10,0">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="0,0,0,15" Padding="0" CornerRadius="12" HasShadow="True" BorderColor="Transparent">
                        <Grid ColumnDefinitions="120,*">
                            <Image Grid.Column="0" Source="{Binding ImagenURL}" HeightRequest="120" Aspect="AspectFill" />
                            <StackLayout Grid.Column="1" Margin="15,10">
                                <Label Text="{Binding Nombre}" FontSize="20" FontAttributes="Bold" TextColor="#1A1A1A" />
                                <Label Text="{Binding Tipo}" FontSize="16" TextColor="#D35400" FontAttributes="Italic" Margin="0,0,0,5" />
                                <Grid ColumnDefinitions="Auto,Auto">
                                    <Label Grid.Column="0" Text="{Binding ABV, StringFormat='ABV: {0}%'}" FontSize="14" TextColor="Gray" Margin="0,0,15,0" />
                                    <Label Grid.Column="1" Text="{Binding IBU, StringFormat='IBU: {0}'}" FontSize="14" TextColor="Gray" />
                                </Grid>
                            </StackLayout>
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button Grid.Row="2" 
                Text="+ Agregar Nueva Cerveza" 
                FontSize="18"
                FontAttributes="Bold"
                BackgroundColor="#2C3E50" 
                TextColor="White" 
                Margin="15" 
                CornerRadius="10"
                Clicked="OnAgregarClicked" />
    </Grid>
</ContentPage>