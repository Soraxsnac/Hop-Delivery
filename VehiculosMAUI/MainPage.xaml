<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VehiculosMAUI.MainPage"
             Title="Catálogo de Cervezas"
             BackgroundColor="#F5F5F5">

    <Grid RowDefinitions="Auto,*,Auto">

        <Label Grid.Row="0" Text="Nuestras Cervezas" FontSize="28" FontAttributes="Bold" Margin="20,15,20,5" TextColor="#333333" />

        <CollectionView Grid.Row="1" x:Name="CervezasCollection" Margin="10,0"
                        SelectionMode="Single"
                        SelectionChanged="OnCervezaSeleccionada">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="10,10,10,15" Padding="0" CornerRadius="20" HasShadow="True" BorderColor="Transparent" BackgroundColor="White">
                        <StackLayout>
                            <Image Source="{Binding ImagenURL}" HeightRequest="200" Aspect="AspectFill" />

                            <StackLayout Padding="20,15">
                                <Label Text="{Binding Nombre}" FontSize="22" FontAttributes="Bold" TextColor="#1A1A1A" />
                                <Label Text="{Binding Tipo}" FontSize="16" TextColor="#D35400" FontAttributes="Italic" Margin="0,0,0,12" />

                                <Grid ColumnDefinitions="*,*">
                                    <StackLayout Grid.Column="0" Orientation="Horizontal">
                                        <Label Text="🍻 " FontSize="16" />
                                        <Label Text="{Binding ABV, StringFormat='ABV: {0}%'}" FontSize="15" TextColor="#555555" FontAttributes="Bold" VerticalOptions="Center"/>
                                    </StackLayout>

                                    <StackLayout Grid.Column="1" Orientation="Horizontal" HorizontalOptions="End">
                                        <Label Text="🌿 " FontSize="16" />
                                        <Label Text="{Binding IBU, StringFormat='IBU: {0}'}" FontSize="15" TextColor="#555555" FontAttributes="Bold" VerticalOptions="Center"/>
                                    </StackLayout>
                                </Grid>
                            </StackLayout>
                        </StackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button Grid.Row="2" 
                Text="+ Agregar Nueva Cerveza" 
                FontSize="18"
                FontAttributes="Bold"
                BackgroundColor="#2C3E50" 
                TextColor="White" 
                Margin="20,10,20,20" 
                CornerRadius="15"
                HeightRequest="55"
                Clicked="OnAgregarClicked" />
    </Grid>
</ContentPage>