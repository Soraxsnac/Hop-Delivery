<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:syncfusion="clr-namespace:Syncfusion.Maui.Inputs;assembly=Syncfusion.Maui.Inputs"
             xmlns:core="clr-namespace:Syncfusion.Maui.Core;assembly=Syncfusion.Maui.Core"
             xmlns:buttons="clr-namespace:Syncfusion.Maui.Buttons;assembly=Syncfusion.Maui.Buttons"
             x:Class="VehiculosMAUI.Views.RegistrarVehiculoPage"
             Title="Registrar Vehículo"
             BackgroundColor="#F5F5F5">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="0">

            <!-- Header Card -->
            <Border BackgroundColor="White"
                    Stroke="Transparent"
                    StrokeThickness="0"
                    Margin="0,10,0,20">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="15"/>
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="Black" 
                            Opacity="0.1" 
                            Radius="10" 
                            Offset="0,2"/>
                </Border.Shadow>

                <VerticalStackLayout Padding="20" Spacing="8">
                    <Label Text="🚗" 
                           FontSize="48"
                           HorizontalOptions="Center"/>
                    <Label Text="Nuevo Vehículo" 
                           FontSize="24"
                           FontAttributes="Bold"
                           HorizontalTextAlignment="Center"
                           TextColor="#212121"/>
                    <Label Text="Complete los datos del vehículo" 
                           FontSize="14"
                           HorizontalTextAlignment="Center"
                           TextColor="#757575"/>
                </VerticalStackLayout>
            </Border>

            <!-- Form Card -->
            <Border BackgroundColor="White"
                    Stroke="Transparent"
                    StrokeThickness="0"
                    Margin="0,0,0,20">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="15"/>
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="Black" 
                            Opacity="0.1" 
                            Radius="10" 
                            Offset="0,2"/>
                </Border.Shadow>

                <VerticalStackLayout Padding="20" Spacing="20">

                    <!-- Placas Field -->
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Placas del Vehículo" 
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="#424242"/>
                        <core:SfTextInputLayout 
                            Hint="Ingrese las placas"
                            HelperText="Ejemplo: ABC-1234"
                            ContainerType="Outlined"
                            OutlineCornerRadius="10"
                            Stroke="#E0E0E0">
                            <Entry x:Name="entryPlacas"
                                   Placeholder="ABC-1234"
                                   MaxLength="10"
                                   CharacterSpacing="1"
                                   FontSize="16"
                                   TextColor="#212121"/>
                        </core:SfTextInputLayout>
                    </VerticalStackLayout>

                    <!-- Marca Field -->
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Marca" 
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="#424242"/>
                        <syncfusion:SfComboBox 
                            x:Name="comboMarca"
                            Placeholder="Seleccione una marca"
                            DisplayMemberPath="Marca"
                            TextMemberPath="Marca"
                            IsEditable="True"
                            TextSearchMode="Contains"
                            MaxDropDownHeight="200"
                            DropDownPlacement="Auto"
                            HeightRequest="50"/>
                    </VerticalStackLayout>

                    <!-- Modelo Field -->
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Modelo" 
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="#424242"/>
                        <core:SfTextInputLayout 
                            Hint="Ingrese el modelo"
                            HelperText="Ejemplo: Civic, Corolla, F-150"
                            ContainerType="Outlined"
                            OutlineCornerRadius="10"
                            Stroke="#E0E0E0">
                            <Entry x:Name="entryModelo"
                                   Placeholder="Modelo del vehículo"
                                   FontSize="16"
                                   TextColor="#212121"/>
                        </core:SfTextInputLayout>
                    </VerticalStackLayout>

                    <!-- Año Field -->
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Año" 
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="#424242"/>
                        <core:SfTextInputLayout 
                            Hint="Ingrese el año"
                            HelperText="Año de fabricación (1900-2030)"
                            ContainerType="Outlined"
                            OutlineCornerRadius="10"
                            Stroke="#E0E0E0">
                            <syncfusion:SfNumericEntry 
                                x:Name="numericAnio"
                                Placeholder="2024"
                                Minimum="1900"
                                Maximum="2030"
                                Value="2024"
                                CustomFormat="0"
                                AllowNull="False"
                                FontSize="16"
                                TextColor="#212121"/>
                        </core:SfTextInputLayout>
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </Border>

            <!-- Action Buttons -->
            <Grid ColumnDefinitions="*,*" 
                  ColumnSpacing="15"
                  Margin="0,10,0,20">

                <!-- Cancel Button -->
                <buttons:SfButton 
                    Grid.Column="0"
                    Text="Cancelar"
                    FontSize="16"
                    FontAttributes="Bold"
                    CornerRadius="10"
                    HeightRequest="54"
                    BackgroundColor="#F5F5F5"
                    TextColor="#6200EE"
                    Stroke="#E0E0E0"
                    StrokeThickness="1"
                    Clicked="OnCancelarClicked">
                    <buttons:SfButton.Shadow>
                        <Shadow Brush="Black" 
                                Opacity="0.05" 
                                Radius="8" 
                                Offset="0,2"/>
                    </buttons:SfButton.Shadow>
                </buttons:SfButton>

                <!-- Save Button -->
                <buttons:SfButton 
                    Grid.Column="1"
                    x:Name="btnGuardar"
                    Text="Guardar"
                    FontSize="16"
                    FontAttributes="Bold"
                    CornerRadius="10"
                    HeightRequest="54"
                    BackgroundColor="#6200EE"
                    TextColor="White"
                    Clicked="OnGuardarClicked">
                    <buttons:SfButton.Shadow>
                        <Shadow Brush="#6200EE" 
                                Opacity="0.3" 
                                Radius="10" 
                                Offset="0,4"/>
                    </buttons:SfButton.Shadow>
                </buttons:SfButton>
            </Grid>

            <!-- Info Footer -->
            <Border BackgroundColor="#E3F2FD"
                    Stroke="#2196F3"
                    StrokeThickness="1"
                    Padding="15"
                    Margin="0,0,0,20">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10"/>
                </Border.StrokeShape>

                <HorizontalStackLayout Spacing="10">
                    <Label Text="ℹ️" 
                           FontSize="20"
                           VerticalOptions="Start"/>
                    <Label VerticalOptions="Center">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="Tip: " 
                                      FontAttributes="Bold"
                                      TextColor="#1976D2"/>
                                <Span Text="Asegúrese de ingresar los datos correctamente. Todos los campos son obligatorios."
                                      TextColor="#424242"/>
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>
                </HorizontalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>